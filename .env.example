# Variáveis públicas do frontend (Vite)
# Estes valores vão para o bundle — NUNCA coloque segredos privados aqui.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Equivalentes para scripts/CLI sem prefixo VITE_
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Segredos privados (Asaas, SMTP, webhooks, etc) NÃO vão aqui.
# Configure-os em: Lovable Cloud → Edge Function Secrets.
